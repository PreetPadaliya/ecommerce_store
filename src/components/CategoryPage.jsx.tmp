            { id: 'f4', name: 'Casual Shirt', price: 39.99, image: 'https://images.unsplash.com/photo-1598033129183-c4f50c736f10?auto=format&fit=crop&w=600&q=80', rating: 4.2, description: 'Versatile casual shirt made from breathable fabric for everyday wear.' },
